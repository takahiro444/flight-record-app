{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": [
        "dynamodb:PutItem",
        "dynamodb:GetItem",
        "dynamodb:UpdateItem",
        "dynamodb:Query",
        "dynamodb:Scan"
      ],
      "Resource": [
        "arn:aws:dynamodb:us-west-2:<account-id>:table/flight-email-parse-jobs",
        "arn:aws:dynamodb:us-west-2:<account-id>:table/flight-email-parse-jobs/*"
      ]
    },
    {
      "Effect": "Allow",
      "Action": [
        "lambda:InvokeFunction"
      ],
      "Resource": "arn:aws:lambda:us-west-2:<account-id>:function:proxy-email-parser-agent"
    },
    {
      "Effect": "Allow",
      "Action": [
        "bedrock:InvokeAgent",
        "bedrock:InvokeAgentRuntime",
        "bedrock-agentcore:InvokeAgentRuntime"
      ],
      "Resource": "*"
    }
  ]
}
