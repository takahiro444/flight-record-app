{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DynamoDBAccessForChatJobs",
      "Effect": "Allow",
      "Action": [
        "dynamodb:PutItem",
        "dynamodb:GetItem",
        "dynamodb:UpdateItem"
      ],
      "Resource": "arn:aws:dynamodb:us-west-2:<account-id>:table/flight-chat-jobs"
    },
    {
      "Sid": "InvokeSelfAsync",
      "Effect": "Allow",
      "Action": "lambda:InvokeFunction",
      "Resource": "arn:aws:lambda:us-west-2:<account-id>:function:proxy-flight-record-bedrock-agent"
    }
  ]
}
