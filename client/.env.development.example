# Copy this file to .env.development (gitignored) and fill in your values.
# Used by the local CRA dev server + setupProxy.js only — never bundled into the app.

REACT_APP_API_BASE_URL=/apiGateway
REACT_APP_COGNITO_DOMAIN=https://<cognito-domain>.auth.<region>.amazoncognito.com
REACT_APP_COGNITO_CLIENT_ID=<your-cognito-app-client-id>
REACT_APP_COGNITO_REDIRECT_URI=http://localhost:3000/
REACT_APP_COGNITO_LOGOUT_URI=http://localhost:3000/

# Dev proxy settings (read by setupProxy.js at dev-server startup, not bundled)
DEV_PROXY_API_TARGET=https://<api-gateway-id>.execute-api.<region>.amazonaws.com/prod
DEV_PROXY_WAF_REFERER=https://<s3-bucket-name>.s3.<region>.amazonaws.com/
