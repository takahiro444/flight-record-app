# Copy this file to .env.production (gitignored) for local production builds.
# In CI/CD (GitHub Actions), these are injected from repository Secrets — no file needed.

REACT_APP_API_BASE_URL=https://<api-gateway-id>.execute-api.<region>.amazonaws.com/prod
REACT_APP_COGNITO_DOMAIN=https://<cognito-domain>.auth.<region>.amazoncognito.com
REACT_APP_COGNITO_CLIENT_ID=<your-cognito-app-client-id>
REACT_APP_COGNITO_REDIRECT_URI=https://<cloudfront-domain>/app
REACT_APP_COGNITO_LOGOUT_URI=https://<cloudfront-domain>/app
